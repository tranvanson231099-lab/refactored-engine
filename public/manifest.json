{
  "manifest_version": 3,
  "name": "VietFlex Engine 2.1.6",
  "version": "2.1.6",
  "description": "Smart Vietnamese IME Optimized for Chrome OS Flex. Rules: i/y & Smart Backspace.",
  "permissions": [
    "input"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "input_components": [
    {
      "name": "VietFlex Telex",
      "id": "vietflex_telex",
      "language": "vi",
      "layouts": ["us"]
    }
  ],
  "icons": {
    "128": "https://picsum.photos/seed/vietflex/128/128"
  },
  "action": {
    "default_popup": "index.html"
  }
}