
{
  "manifest_version": 3,
  "name": "VietFlex Engine 2.1.6",
  "version": "2.1.6",
  "description": "Bộ gõ tiếng Việt thông minh tối ưu cho Chrome OS Flex",
  "permissions": ["storage", "notifications"],
  "action": {
    "default_popup": "index.html",
    "default_title": "VietFlex Panel"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
