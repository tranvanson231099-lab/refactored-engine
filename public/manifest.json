
{
  "manifest_version": 3,
  "name": "VietFlex Engine 2.1.6",
  "version": "2.1.6",
  "description": "Bộ gõ tiếng Việt chuyên sâu tối ưu cho Chrome OS Flex",
  "permissions": ["input", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "input_components": [
    {
      "name": "VietFlex Telex",
      "id": "vietflex_telex",
      "language": "vi",
      "layouts": ["us"]
    }
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "VietFlex Settings"
  },
  "icons": {
    "16": "https://picsum.photos/seed/vietflex/16/16",
    "48": "https://picsum.photos/seed/vietflex/48/48",
    "128": "https://picsum.photos/seed/vietflex/128/128"
  }
}
