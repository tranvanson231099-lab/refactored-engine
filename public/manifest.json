
{
  "manifest_version": 3,
  "name": "VietFlex Engine 2.1.6",
  "version": "2.1.6",
  "description": "Bộ gõ tiếng Việt thông minh cho Chrome OS Flex",
  "permissions": ["input", "notifications", "tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Mở Bảng điều khiển VietFlex"
  },
  "options_page": "index.html",
  "input_components": [
    {
      "name": "VietFlex Telex",
      "id": "vietflex_telex",
      "language": "vi",
      "layouts": ["us"]
    }
  ]
}
