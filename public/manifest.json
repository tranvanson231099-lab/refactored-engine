{
  "manifest_version": 3,
  "name": "VietFlex Telex IME",
  "version": "2.1.6",
  "description": "Smart Vietnamese Input Method for Chrome OS Flex",
  "permissions": [
    "inputMethodPrivate"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "input_components": [
    {
      "name": "VietFlex Telex",
      "id": "vietflex_telex",
      "language": "vi",
      "layouts": ["us"]
    }
  ],
  "action": {
    "default_popup": "index.html"
  }
}