
{
  "manifest_version": 3,
  "name": "VietFlex Engine 2.1.6",
  "version": "2.1.6",
  "description": "Modern Vietnamese IME for Chrome OS Flex with Smart i/y and 3-step Backspace",
  "permissions": ["input"],
  "background": {
    "service_worker": "background.js"
  },
  "input_components": [
    {
      "name": "VietFlex Telex",
      "id": "vietflex_telex",
      "language": "vi",
      "layouts": ["us"]
    }
  ],
  "icons": {
    "16": "https://picsum.photos/seed/vietflex/16/16",
    "48": "https://picsum.photos/seed/vietflex/48/48",
    "128": "https://picsum.photos/seed/vietflex/128/128"
  }
}
