{
  "manifest_version": 3,
  "name": "VietFlex Engine 2.1.6",
  "version": "2.1.6",
  "description": "Bộ gõ tiếng Việt siêu tốc cho Chrome OS Flex (Telex & Smart i/y)",
  "permissions": [
    "input"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "input_components": [
    {
      "name": "VietFlex Telex",
      "id": "vietflex_telex",
      "language": "vi",
      "layouts": ["us"],
      "input_view": "index.html"
    }
  ]
}