
{
  "manifest_version": 3,
  "name": "VietFlex Engine 2.1.6",
  "version": "2.1.6",
  "description": "Bộ gõ tiếng Việt chuyên nghiệp cho Chrome OS Flex",
  "action": {
    "default_popup": "index.html",
    "default_icon": "https://picsum.photos/seed/vietflex/128/128"
  },
  "icons": {
    "128": "https://picsum.photos/seed/vietflex/128/128"
  },
  "permissions": ["storage"],
  "input_components": [
    {
      "name": "VietFlex Telex",
      "id": "vietflex-telex",
      "language": "vi",
      "layouts": ["us"],
      "input_view": "index.html"
    }
  ]
}
