{
  "manifest_version": 3,
  "name": "VietFlex Engine 2.1.6",
  "version": "2.1.6",
  "description": "Bộ gõ tiếng Việt chuyên sâu cho Chrome OS Flex - Chuẩn 5 quy tắc i/y.",
  "permissions": ["input", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "input_components": [
    {
      "name": "VietFlex Telex",
      "id": "vietflex_telex",
      "language": "vi",
      "layouts": ["us"],
      "input_view": "index.html"
    }
  ],
  "icons": {
    "128": "https://picsum.photos/seed/vietflex/128/128"
  },
  "action": {
    "default_popup": "index.html"
  }
}
