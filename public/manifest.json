
{
  "manifest_version": 3,
  "name": "VietFlex Engine 2.1.6",
  "version": "2.1.6",
  "description": "Bộ gõ tiếng Việt siêu tốc tối ưu cho Chrome OS Flex",
  "permissions": ["input"],
  "background": {
    "service_worker": "background.js"
  },
  "input_components": [
    {
      "name": "VietFlex Telex",
      "id": "vietflex_telex",
      "language": "vi",
      "layouts": ["us"]
    }
  ],
  "action": {
    "default_popup": "index.html"
  },
  "icons": {
    "128": "https://picsum.photos/seed/vietflex/128/128"
  }
}
