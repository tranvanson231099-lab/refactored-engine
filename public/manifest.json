
{
  "manifest_version": 3,
  "name": "VietFlex Engine 2.1.6",
  "version": "2.1.6",
  "description": "Bộ gõ tiếng Việt chuyên biệt cho Chrome OS Flex",
  "permissions": [
    "input",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "input_components": [
    {
      "name": "VietFlex Telex",
      "id": "vietflex_telex",
      "language": "vi",
      "layouts": ["us"],
      "type": "ime"
    }
  ],
  "action": {
    "default_popup": "index.html"
  },
  "icons": {
    "128": "icon128.png"
  }
}
